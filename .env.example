# Copy to .env (gitignored) and fill in. AutoDev loads .env at start.

# --- Secrets (never commit real values) ---
ANTHROPIC_API_KEY=sk-ant-...
# Fine-grained PAT scoped to servitium-api ONLY, contents + pull_requests:write,
# NO merge/admin/branch-protection, workflows permission OFF.
GITHUB_PAT=github_pat_...
DASH_SESSION_SECRET=

# --- Org / scope ---
GITHUB_ORG=fabienavedissian
TARGET_REPOS=servitium-api

# --- Spend caps (USD) ---
MONTHLY_SPEND_CAP_USD=100
DAILY_SPEND_CAP_USD=10
PER_TASK_BUDGET_USD=10

# --- Anti-loop ---
MAX_LOOPS_PER_TASK=4
MAX_OPUS_REENTRIES=1
MAX_TURNS_PER_STEP=12

# --- Cadence ---
POLL_INTERVAL_MIN=15

# --- Paths ---
DB_PATH=./autodev.db
WORK_ROOT=./.work
MIRROR_ROOT=./.mirrors

# --- Dashboard ---
API_AUTH_URL=https://api.servitium.org/auth/login
COOKIE_DOMAIN=.servitium.org

LOG_LEVEL=info
