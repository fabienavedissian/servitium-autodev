{
  "name": "servitium-autodev",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous chain-of-agents engineering loop for Servitium (v1: servitium-api). Opens merge-ready DRAFT PRs; never merges, never deploys.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:ci": "jest --runInBand --ci",
    "smoketest": "npm run build && node --env-file-if-exists=.env dist/scripts/sdk-smoketest.js",
    "start": "node --env-file-if-exists=.env dist/src/index.js",
    "dashboard": "node --env-file-if-exists=.env dist/src/dashboard/server.js",
    "seed:proposals": "node --env-file-if-exists=.env dist/scripts/seed-proposals.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.177",
    "@anthropic-ai/sdk": "0.104.1",
    "better-sqlite3": "12.10.0",
    "octokit": "5.0.5",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.3",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3"
  }
}
